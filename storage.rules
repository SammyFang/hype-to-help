rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // The current MVP does not persist uploads in Cloud Storage.
    // Keep Storage closed until Firebase Auth and a server-side upload flow are enabled.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Future authenticated upload path:
    // match /fan-quest-uploads/{userId}/{fileName} {
    //   allow read: if request.auth != null && request.auth.uid == userId;
    //   allow write: if request.auth != null
    //     && request.auth.uid == userId
    //     && request.resource.size < 5 * 1024 * 1024
    //     && request.resource.contentType.matches('image/.*');
    // }
  }
}
